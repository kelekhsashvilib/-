<!DOCTYPE html>
<html lang="ka">
<head>
<meta charset="UTF-8">
<title>Love Countdown ❤️</title>

<style>
body {
  margin: 0;
  height: 100vh;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #ff758c, #ff7eb3);
  font-family: 'Arial', sans-serif;
  color: white;
  position: relative;
}

/* ფონური ტექსტი */
.background-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 120px;
  font-weight: bold;
  background: linear-gradient(90deg, #00cfff, #0077ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 2px 2px 8px rgba(0,0,0,0.4);
  white-space: nowrap;
  z-index: 0;
  pointer-events: none;
}

.container {
  text-align: center;
  z-index: 2;
}

.title {
  font-size: 30px;
  font-weight: bold;
  margin-bottom: 20px;
}

.countdown {
  display: flex;
  gap: 15px;
  justify-content: center;
}

.box {
  background: rgba(255,255,255,0.2);
  padding: 20px;
  border-radius: 20px;
  backdrop-filter: blur(10px);
}

.number {
  font-size: 50px;
  font-weight: bold;
}

.label {
  font-size: 14px;
}

.finished {
  font-size: 35px;
  margin-top: 20px;
}

/* გულები */
.heart {
  position: absolute;
  color: rgba(255,255,255,0.6);
  font-size: 20px;
  animation: floatUp 6s linear infinite;
}

@keyframes floatUp {
  0% { transform: translateY(100vh); opacity: 1; }
  100% { transform: translateY(-10vh); opacity: 0; }
}
</style>
</head>

<body>

<div class="background-text">უკან მომავალში</div>

<div class="container">
  <div class="title">💖 შენამდე დარჩა 💖</div>

  <div class="countdown">
    <div class="box">
      <div class="number" id="days">0</div>
      <div class="label">დღე</div>
    </div>
    <div class="box">
      <div class="number" id="hours">0</div>
      <div class="label">საათი</div>
    </div>
    <div class="box">
      <div class="number" id="minutes">0</div>
      <div class="label">წუთი</div>
    </div>
    <div class="box">
      <div class="number" id="seconds">0</div>
      <div class="label">წამი</div>
    </div>
  </div>

  <div id="done" class="finished"></div>
</div>

<!-- მუსიკა -->
<audio id="music" loop>
  <source src="https://www.bensound.com/bensound-music/bensound-love.mp3" type="audio/mpeg">
</audio>

<script>
// ფიქსირებული თარიღი
const targetDate = new Date("2026-06-21T00:00:00");

// ელემენტები
const daysEl = document.getElementById("days");
const hoursEl = document.getElementById("hours");
const minutesEl = document.getElementById("minutes");
const secondsEl = document.getElementById("seconds");
const doneEl = document.getElementById("done");

// countdown
function updateCountdown() {
  const now = new Date();
  const diff = targetDate - now;

  if (diff <= 0) {
    doneEl.innerText = "💘 ეს დღე მოვიდა 💘";
    return;
  }

  const total = Math.floor(diff / 1000);

  daysEl.innerText = Math.floor(total / 86400);
  hoursEl.innerText = Math.floor((total % 86400) / 3600);
  minutesEl.innerText = Math.floor((total % 3600) / 60);
  secondsEl.innerText = total % 60;
}

setInterval(updateCountdown, 1000);

// გულები
function createHeart() {
  const heart = document.createElement("div");
  heart.classList.add("heart");
  heart.innerText = "💖";
  heart.style.left = Math.random() * 100 + "vw";
  heart.style.fontSize = (15 + Math.random() * 20) + "px";
  heart.style.animationDuration = (4 + Math.random() * 3) + "s";
  document.body.appendChild(heart);

  setTimeout(() => heart.remove(), 6000);
}
setInterval(createHeart, 300);

// მუსიკა (user interaction)
document.body.addEventListener("click", () => {
  document.getElementById("music").play();
}, { once: true });
</script>

</body>
</html>
